# EVERCLEAN LUXURY SERVICES - Environment Variables
# Copy this file to .env.local for development

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/everclean"
DIRECT_URL="postgresql://user:password@localhost:5432/everclean"

# =============================================================================
# AUTHENTICATION (NextAuth.js v5)
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Google OAuth (Optional - for client portal)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
# Test keys for development
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Live keys for production
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_SECRET_KEY="sk_live_..."

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="concierge@everclean.ca"
ADMIN_EMAIL="admin@everclean.ca"

# =============================================================================
# SMS (Twilio)
# =============================================================================
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+15195551234"

# =============================================================================
# REDIS (Upstash) - For rate limiting
# =============================================================================
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# =============================================================================
# MONITORING (Sentry)
# =============================================================================
SENTRY_DSN="https://..."

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Everclean Luxury Services"
NEXT_PUBLIC_COMPANY_PHONE="+1 (519) 555-0123"
NEXT_PUBLIC_COMPANY_EMAIL="concierge@everclean.ca"

# Feature Flags
ENABLE_PAYMENTS="true"
ENABLE_SMS_NOTIFICATIONS="false"
ENABLE_EMAIL_NOTIFICATIONS="true"

# =============================================================================
# GOOGLE PLACES API (For address autocomplete)
# =============================================================================
GOOGLE_PLACES_API_KEY=""
