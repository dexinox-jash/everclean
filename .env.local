# =============================================================================
# EVERCLEAN LUXURY SERVICES - ENVIRONMENT CONFIGURATION V2.0
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# Using PostgreSQL with Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/everclean"
DIRECT_URL="postgresql://postgres:password@localhost:5432/everclean"

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# Generate a random secret: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-random-key-min-32-characters-long"

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# Payment Processing (Stripe)
# Get from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe Price IDs for services
STRIPE_PRICE_ESTATE="price_xxx"
STRIPE_PRICE_RESIDENCE="price_xxx"
STRIPE_PRICE_CONCIERGE="price_xxx"

# -----------------------------------------------------------------------------
# Email Service (Resend)
# Get from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="Everclean <hello@everclean.ca>"
RESEND_FROM_NAME="Everclean Luxury Services"

# Admin notification email
ADMIN_EMAIL="admin@everclean.ca"

# -----------------------------------------------------------------------------
# SMS Service (Twilio) - Optional
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="AC_your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_PAYMENTS="true"
ENABLE_EMAIL_NOTIFICATIONS="true"
ENABLE_SMS_NOTIFICATIONS="false"
ENABLE_BOOKING_CONFIRMATION="true"

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
APP_NAME="Everclean Luxury Services"
APP_TAGLINE="Bespoke cleaning for discerning homeowners"
COMPANY_PHONE="+1 (519) 555-0123"
COMPANY_EMAIL="hello@everclean.ca"
COMPANY_ADDRESS="Kitchener-Waterloo, Ontario, Canada"

# Business Hours
BUSINESS_HOURS_START="08:00"
BUSINESS_HOURS_END="18:00"
BUSINESS_TIMEZONE="America/Toronto"

# Booking Settings
MIN_BOOKING_HOURS=2
MAX_BOOKING_HOURS=12
BOOKING_LEAD_TIME_HOURS=24

# -----------------------------------------------------------------------------
# Rate Limiting (Upstash Redis)
# Get from: https://console.upstash.com
# -----------------------------------------------------------------------------
REDIS_URL="https://your-upstash-redis-url.upstash.io"
REDIS_TOKEN="your-upstash-redis-token"

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# Get from: https://sentry.io
# -----------------------------------------------------------------------------
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Sentry Auth Token for source maps (optional, for CI/CD)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="everclean"

# -----------------------------------------------------------------------------
# Real-time Features (Ably or Pusher)
# Optional - for real-time admin dashboard updates
# -----------------------------------------------------------------------------
ABLY_API_KEY="your-ably-api-key"
NEXT_PUBLIC_ABLY_KEY="your-ably-public-key"

# -----------------------------------------------------------------------------
# Subscription Settings
# -----------------------------------------------------------------------------
SUBSCRIPTION_TRIAL_DAYS=0
SUBSCRIPTION_GRACE_PERIOD_DAYS=3

# -----------------------------------------------------------------------------
# Staff Mobile PWA
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STAFF_APP_URL="/staff"

# =============================================================================
